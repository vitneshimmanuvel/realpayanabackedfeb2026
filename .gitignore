# =========================
# Node.js backend .gitignore
# =========================

# Node modules
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment variables
.env
.env.*
!.env.example

# 🔐 Service account & secret keys
*.json
!package.json
!package-lock.json

# Build output
dist/
build/
out/

# Logs
logs/
*.log
pids/
*.pid
*.seed
*.pid.lock

# Coverage reports
coverage/
*.lcov

# Temporary files
.tmp/
.temp/
cache/
.nyc_output/

# OS generated files
.DS_Store
Thumbs.db

# IDE / Editor folders
.vscode/
.idea/

# TypeScript
*.tsbuildinfo

# Optional: Prisma
prisma/migrations/

# Optional: Sequelize
.sequelize/

# Optional: Docker
docker-compose.override.yml
Dockerfile.dev

# Test reports
jest-html-reporters-*
test-results.xml